<%= form_with(model: medium) do |form| %>

  <div class="grid grid-cols-3 gap-4 mt-4 mx-4">

     <div>
        <%= form.label :media_type, class: label_class %>

        <% error_id = @medium.errors[:media_type].any? ? "#{@medium.model_name.singular}_media_type_error" : nil %>

        <%= form.text_field :media_type,
        class: error_class(medium, :media_type, base: tight_form_input_class),
        aria: { invalid: @medium.errors[:media_type].any?, describedby: error_id } %>

    <%= field_error_for(@medium, :media_type, id: error_id) %>
     </div>
    
    <div>
      <%= form.label :company_name, class: label_class %>

      <% error_id = medium.errors[:company_name].any? ? "#{medium.model_name.singular}_company_name_error" : nil %>
      <%= form.text_field :company_name,
          class: error_class(medium, :company_name, base: tight_form_input_class),
          aria: { invalid: medium.errors[:company_name].any?, describedby: error_id } %>

      <%= field_error_for(medium, :company_name, id: error_id) %>
    </div>
    

    <div>
      <%= form.label :company_website, class: label_class %>
      <%= form.text_field :company_website, class: tight_form_input_class %>
    </div>

    <div>
      <%= form.label :contact_name,  class: label_class %>
      <%= form.text_area :contact_name, rows: 2, class: tight_form_input_class  %>
    </div>

    <div>
      <%= form.label :contact_position,  class: label_class %>
      <%= form.text_area :contact_position, rows: 2, class: tight_form_input_class  %>
    </div>

    <div>
      <%= form.label :contact_email,  class: label_class %>
      <%= form.text_area :contact_email, rows: 2, class: tight_form_input_class  %>
    </div>

    <div>
      <%= form.label :email, "General Email", class: label_class %>
      <%= form.text_area :email, rows: 2, class: tight_form_input_class  %>
    </div>

    <div>
      <%= form.label :phone,  class: label_class %>
      <%= form.text_area :phone, rows: 2, class: tight_form_input_class  %>
    </div>

    <div>
      <%= form.label :socials,  "Other Socials", class: label_class %>
      <%= form.text_area :socials, rows: 2, class: tight_form_input_class  %>
    </div> 

    <div>
      <%= form.label :facebook,  class: label_class %>
      <%= form.text_field :facebook, class: tight_form_input_class  %>
    </div>

    <div>
      <%= form.label :twitter, "X", class: label_class %>
      <%= form.text_field :twitter, class: tight_form_input_class  %>
    </div>

    <div>
      <%= form.label :instagram,  class: label_class %>
      <%= form.text_field :instagram, class: tight_form_input_class  %>
    </div>

    <div class="col-span-2">
      <%= form.label :event_calender_link, "Event Calendar Link", class: label_class %>
      <%= form.text_field :event_calender_link, class: tight_form_input_class %>
    </div>

    <div>
      <%= form.label :calendar_login_details,  class: label_class %>
      <%= form.text_field :calendar_login_details, class: tight_form_input_class %>
    </div>

    <div>
      <%= form.label :city,  class: label_class %>
      <%= form.text_field :city, class: tight_form_input_class %>
    </div>

    <div>
      <%= form.label :state,  class: label_class %>
      <%= form.select :state, options_for_select(us_states, medium.state), { prompt: "Select a state" }, class: tight_form_input_class %>
    </div>

    <div>
      <%= form.label :country,  class: label_class %>
      <%= form.text_field :country, class: tight_form_input_class  %>
    </div>

    <div class="col-span-2">
      <%= form.label :notes,  class: label_class %>
      <%= form.text_area :notes, rows: 5, class: tight_form_input_class  %>
    </div>

    <div>
      <%= form.label :region_other,  "Region if NOT USA State", class: label_class %>
     <%= form.text_field :region_other, class: "#{tight_form_input_class} mb-4" %>
   
      <%= form.label :allocated_to, class: label_class%>
     
<div class="mt-1">
  <%= form.collection_select :user_id,
        @users,
        :id,
        :full_name,
        { include_blank: "Please select" },
        class: input_class %>
</div>
    </div>

    <div class="col-span-3">
      <%= form.label :pitch,  class: label_class %>
      <%= form.text_area :pitch, rows: 3, class: tight_form_input_class  %>
    </div>

    <div class="col-span-3">
      <%= form.label :action_taken,  class: label_class %>
      <%= form.text_area :action_taken, rows: 3, class: tight_form_input_class  %>
    </div>
  </div>
  <%= form.hidden_field :old_user_id, value: medium.user_id%>

     <p class="text-md font-semibold mt-4 ml-2">Press Releases</p>

     <div data-controller="press-releases" class="border border-gray-400 rounded m-2">
     <div data-press-releases-target="container" class="space-y-4">
       <%= form.fields_for :press_releases do |pr_form| %>
         <%= render "press_release_fields", f: pr_form %>
       <% end %>
     </div>
   
     <template data-press-releases-target="template">
       <%= form.fields_for :press_releases, PressRelease.new, child_index: "NEW_RECORD" do |pr_form| %>
         <%= render "press_release_fields", f: pr_form %>
       <% end %>
     </template>
   
     <div class="mt-4 ml-4 mb-2">
       <button type="button"
               data-action="press-releases#add"
               class="bg-blue-100 text-blue-900 hover:bg-blue-200 px-4 py-2 rounded shadow-sm text-sm">
         + Add Another Press Release
       </button>
     </div>
   </div>
   
    
      
    <div class=mt-3>
      <%= form.submit "Save Media", class: form_button_class %>
    </div>
<% end %>

</div>
