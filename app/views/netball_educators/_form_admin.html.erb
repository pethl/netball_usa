<div class="sm:mx-auto sm:w-full sm:max-w-5xl"> <!-- increased max width for multi-column -->
  <div class="bg-white py-2 px-2 sm:px-6">

    <%= form_with(model: netball_educator, data: { turbo: false }) do |form| %>
      <%= form.hidden_field :role, value: netball_educator.role.presence || (params[:kidokinetics] == "true" ? "Kidokinetics" : nil) %>

      <!-- responsive grid: 1 col mobile, 2 cols md, 3 cols lg -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-4">

      <!-- Your normal educator fields -->

           <div class="mb-4"><!-- First Name* -->
        <%= form.label :first_name, "First Name*", class: label_class %>
        <div class="mt-1">
          <% error_id = netball_educator.errors[:first_name].any? ? "#{netball_educator.model_name.singular}_first_name_error" : nil %>
          <%= form.text_field :first_name,
              class: error_class(netball_educator, :first_name, base: input_class),
              aria: { invalid: netball_educator.errors[:first_name].any?, describedby: error_id } %>
        </div>
        <%= field_error_for(netball_educator, :first_name, id: error_id) %>
      </div>

      <div class="mb-4"><!-- Last Name* -->
        <%= form.label :last_name, "Last Name*", class: label_class %>
        <div class="mt-1">
          <% error_id = netball_educator.errors[:last_name].any? ? "#{netball_educator.model_name.singular}_last_name_error" : nil %>
          <%= form.text_field :last_name,
              class: error_class(netball_educator, :last_name, base: input_class),
              aria: { invalid: netball_educator.errors[:last_name].any?, describedby: error_id } %>
        </div>
        <%= field_error_for(netball_educator, :last_name, id: error_id) %>
      </div>

     <!-- Row break for md+ screens -->
<div></div>

    <!-- Email *-->
      <div class="mb-4">
        <%= form.label :email, "Email*", class: label_class %>
        <div class="mt-1">
          <% error_id = netball_educator.errors[:email].any? ? "#{netball_educator.model_name.singular}_email_error" : nil %>
          <%= form.email_field :email,
              class: error_class(netball_educator, :email, base: input_class),
              aria: { invalid: netball_educator.errors[:email].any?, describedby: error_id } %>
        </div>
        <%= field_error_for(netball_educator, :email, id: error_id) %>
      </div>

      <!-- Gender -->
      <div class="mb-4">
        <%= form.label :gender, "Gender", class: label_class %>
        <div class="mt-1">
          <%= form.select :gender,
            options_for_select(gender, netball_educator.gender),
            { prompt: true },
            class: input_class %>
        </div>
      </div>

      <div class="mb-4"><!-- Cell -->
        <%= form.label :phone, "Cell", class: label_class %>
        <div class="mt-1">
          <%= form.text_field :phone, class: input_class %>
        </div>
      </div>
      

     <div class="mb-4"><!-- Title* -->
        <%= form.label :title, "Title*", class: label_class %>
        <div class="mt-1">
          <% error_id = netball_educator.errors[:title].any? ? "#{netball_educator.model_name.singular}_title_error" : nil %>
          <%= form.select :title,
            options_for_select(educator_title, selected: netball_educator.title),
            { prompt: true },
            class: error_class(netball_educator, :title, base: input_class),
            aria: { invalid: netball_educator.errors[:title].any?, describedby: error_id } %>
        </div>
        <%= field_error_for(netball_educator, :title, id: error_id) %>
      </div>


     <div class="mb-4"><!-- School Name -->
      <%= form.label :school_name, kidokinetics?(netball_educator) ? "Franchise Name*" : "School/Organization Name*", class: label_class %>
      <div class="mt-1">
        <% error_id = netball_educator.errors[:school_name].any? ? "#{netball_educator.model_name.singular}_school_name_error" : nil %>
        <%= form.text_field :school_name,
            class: error_class(netball_educator, :school_name, base: input_class),
            aria: { invalid: netball_educator.errors[:school_name].any?, describedby: error_id } %>
      </div>
      <%= field_error_for(netball_educator, :school_name, id: error_id) %>
    </div>


      <div class="mb-4"><!-- School District -->
        <%= form.label :school_district, "School District (if relevant)", class: label_class %>
        <div class="mt-1">
          <%= form.text_field :school_district, class: input_class %>
        </div>
      </div>

          <div class="mb-4">
          <%= form.label :address, kidokinetics?(netball_educator) ? "Franchise Address" : "School Address", class: label_class %>

            <div class="mt-1">
              <%= form.text_field :address, class: input_class %>
            </div>
          </div>

          <div class="mb-4">
            <%= form.label :city, "City*", class: label_class %>
            <div class="mt-1">
              <%= form.text_field :city, class: input_class %>
            </div>
          </div>

          <div class="mb-4">
            <%= form.label :state, "State*", class: label_class %>
            <div class="mt-1">
              <%= form.select :state, options_for_select(us_states, selected: netball_educator.state), { prompt: true }, class: input_class %>
            </div>
          </div>

          <div class="mb-4">
            <%= form.label :zip, "Zip Code", class: label_class %>
            <div class="mt-1">
              <%= form.text_field :zip, class: input_class %>
            </div>
          </div>

          <div class="mb-4"><!-- Country -->
            <%= form.label :country, "Country", class: label_class %>
            <div class="mt-1">
              <%= form.text_field :country, class: input_class %>
            </div>
          </div>   

          <div class="mb-4">
          <%= form.label :website, kidokinetics?(netball_educator) ? "Franchise Website" : "School Website", class: label_class %>

            <div class="mt-1">
              <%= form.text_field :website, class: input_class %>
            </div>
          </div>

        <% unless kidokinetics?(netball_educator) %>
          <div class="mb-4">
            <%= form.label :level, "School Level", class: label_class %>
            <div class="mt-1">
              <%= form.select :level, options_for_select(educator_level, selected: netball_educator.level), { prompt: true }, class: input_class %>
            </div>
          </div>
        <% end %>

        <% unless kidokinetics?(netball_educator) %>
            <div class="mb-2 col-span-2">
                <%= form.label :feedback, "Feedback and More Information?", class: label_class %>
                <div class="mt-1">
                  <%= form.text_area :feedback, class: input_class, rows: 3 %>
                </div>
              </div>
        <% end %>

      </div>

        <!-- FIELDS NOT TO BE SHOWN TO GENERAL PUBLIC IN FORM -->
        <% unless current_user.nil? %>

        <h3 class="text-sm font-bold text-left text-gray-700 mb-2">Admin Team Only</h3>
          <div class="border-2 border-blue-900 bg-blue-50 rounded-md p-4 my-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-4 gap-y-4">

                <!-- Category ROLE-->
                   <div class="flex flex-col flex-1">
                      <%= form.label :role, "Educator Category", class: label_class %>
                      <%= form.select :role,
                            options_for_select(educator_roles, selected: netball_educator.role),
                            { prompt: "Please select " },
                            class: "#{input_class}  w-full" %>
                   </div>
                
                  <div class="mb-4">
                      <%= form.label :user_id, "Allocated To", class: label_class %>
                      <%= form.collection_select(:user_id, @users, :id, :full_name, { prompt: true }, { class: input_class }) %>
                    </div>
                 
                 <div class="mb-4 col-span-2">
                    <%= form.label :mgmt_notes, "Management Notes", class: label_class %>
                    <%= form.text_area :mgmt_notes,
                          class: input_class,
                          rows: 4 %>
                  </div>
             

          <% if @netball_educator.persisted? %>
              <div class="field">
                <%= form.label :event_ids, "Registered at Event? (scroll to view full list)" %><br>
                <%= form.collection_select :event_ids,
                    Event.all.ordered_desc,
                    :id,
                    :event_date_state_type_name,
                    { prompt: "Please select" },
                    { multiple: true, class: input_class } %>
              </div>
            <% end %>
            </div>
         
        </div>
      </div>
       <% end %> 

      <!-- Submit button for Educator -->
      <div class="mt-2 ml-4">
        <%= form.submit "Save Details", class: form_button_class %>
      </div>

  
  <!-- ✅ Now Equipment Section starts -->
  <div class="mx-6">
    <% if current_user.present? %>
      <% if netball_educator.persisted? %>
        <hr class="my-4 border-gray-300">

        <h2 class="text-lg font-semibold text-gray-700 mb-2">Equipment Sales</h2>

        <% if netball_educator.equipment.any? %>
          <ul class="space-y-2 mb-4">
            <% netball_educator.equipment.each do |equipment| %>
              <li class="flex justify-between items-center p-2 border rounded bg-gray-50">
                <div>
                  <strong><%= equipment.sale_date.to_formatted_s(:usa) if equipment.sale_date %></strong> –
                  <%= equipment.items_purchased %> –
                  <%= number_to_currency(equipment.purchase_amount) %>
                </div>
                <div class="flex gap-2">
                  <%= link_to "Edit", edit_equipment_path(equipment), class: "text-blue-600 hover:underline text-sm" %>
                  <%= link_to "Delete", equipment_path(equipment), method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:underline text-sm" %>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-gray-500 text-sm mb-4">No equipment sales recorded yet.</p>
        <% end %>

        <%= link_to "➕ Add New Equipment Sale", new_equipment_path(netball_educator_id: netball_educator.id), class: "inline-block text-sm text-blue-800 hover:underline" %>

      <% else %>
        <div class="mt-6">
          <p class="text-sm text-gray-500">Save the educator record, then link to event or add equipment sales.</p>
        </div>
      <% end %>
    <% end %>

     <hr class="my-4 border-gray-300">


    <% end %>
  </div>
</div>
